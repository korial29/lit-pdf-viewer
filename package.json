{
  "name": "lit-pdf-viewer",
  "license": "Apache-2.0",
  "version": "1.1.0",
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/korial29/lit-pdf-viewer.git"
  },
  "keywords": [
    "lit-pdf-viewer"
  ],
  "author": "Ludovic Dupont <ludovic.dupont29@gmail.com>",
  "dependencies": {
    "lit": "^2.2.2",
    "pdfjs-dist": "^6.1.200"
  },
  "devDependencies": {
    "@open-wc/eslint-config": "^7.0.0",
    "@open-wc/testing-helpers": "^2.1.2",
    "@types/mocha": "^9.0.0",
    "@types/node": "^20.19.0",
    "@typescript-eslint/eslint-plugin": "^5.5.0",
    "@typescript-eslint/parser": "^5.5.0",
    "@vitest/coverage-v8": "^3.2.6",
    "@vitest/ui": "^3.2.6",
    "c8": "^11.0.0",
    "eslint-config-prettier": "^8.3.0",
    "eslint-import-resolver-alias": "^1.1.2",
    "eslint-plugin-prettier": "^3.4.1",
    "jsdom": "^19.0.0",
    "pdfjs": "^2.4.7",
    "prettier": "^2.5.1",
    "sass": "^1.101.0",
    "typescript": "^4.6.2",
    "typescript-plugin-css-modules": "^3.4.0",
    "vite": "^8.1.0",
    "vite-plugin-static-copy": "^4.1.1",
    "vitest": "^3.2.6"
  },
  "scripts": {
    "start": "cp -r node_modules/pdfjs-dist www && cp -r assets/fonts www && cp -r assets/style www/style && vite www",
    "build": "vite build",
    "lint:eslint": "eslint . --ext .js,.ts",
    "format:eslint": "eslint . --ext .js,.ts --fix",
    "lint:prettier": "prettier --check \"**/*.(js|ts)\"",
    "format:prettier": "prettier \"**/*.{js,ts}\" --write",
    "lint:tsc": "tsc --noEmit",
    "lint": "npm run lint:prettier && npm run lint:eslint && npm run lint:tsc",
    "format": " npm run format:prettier && npm run format:eslint",
    "test": "vitest run --coverage",
    "test:ci": "vitest run --coverage --passWithNoTests",
    "test:update-snapshots": "vitest --update",
    "test:ui": "vitest --ui",
    "test:watch": "vitest --watch"
  }
}
